# .env.example — Template for ~/.claude/.env (gitignored, never committed).
# Copy this file's variable names to ~/.claude/.env and fill in your values.
#
# The update script sources ~/.claude/.env at startup. It expects these variables:

# Discord webhook URLs (Discord: Server Settings → Integrations → Webhooks)
PERSONAL_WEBHOOK=https://discord.com/api/webhooks/YOUR_SERVER_ID/YOUR_TOKEN
PANDASPEC_WEBHOOK=https://discord.com/api/webhooks/YOUR_SERVER_ID/YOUR_TOKEN

# GitHub Personal Access Token for pushing commits
# Required scope: repo (full control of private repositories)
# Create at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_YOUR_TOKEN_HERE
