# .env.example — Template for ~/.claude/.env (gitignored, never committed).
# Copy this file's variable names to ~/.claude/.env and fill in your values.
#
# These variables are expected:

# GitHub Personal Access Token for pushing commits
# Required scope: repo (full control of private repositories)
# Create at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_YOUR_TOKEN_HERE
